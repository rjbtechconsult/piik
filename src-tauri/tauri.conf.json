{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Piik",
  "version": "0.1.5",
  "identifier": "com.realjblaq.piik",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/increment-build-number.js && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Piik",
        "label": "main",
        "width": 364,
        "height": 524,
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "bundleVersion": "21"
    }
  }
}
