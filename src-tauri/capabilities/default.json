{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:allow-execute",
    "sql:allow-load",
    "sql:allow-select",
    "positioner:default",
    "autostart:default",
    "notification:default",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install",
    "process:allow-restart",
    "shell:default"
  ]
}
